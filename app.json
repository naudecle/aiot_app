{
  "expo": {
    "name": "aiot_app",
    "slug": "aiot_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/aiot.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/aiot.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/aiot.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/aiot.png"
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
